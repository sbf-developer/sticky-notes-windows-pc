{
    "name": "stick-notes",
    "version": "1.0.0",
    "description": "Minimal sticky notes for Windows",
    "main": "./out/main/index.js",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "preview": "electron-vite preview",
        "dist": "npm run build && electron-builder"
    },
    "dependencies": {
        "react": "^19.1.0",
        "react-dom": "^19.1.0"
    },
    "devDependencies": {
        "@types/react": "^19.1.0",
        "@types/react-dom": "^19.1.0",
        "@vitejs/plugin-react": "^4.5.0",
        "electron": "^36.0.0",
        "electron-builder": "^26.0.0",
        "electron-vite": "^3.1.0",
        "typescript": "^5.8.0",
        "vite": "^6.3.0"
    },
    "build": {
        "appId": "com.sticknotes.app",
        "productName": "Sticky Notes",
        "directories": {
            "output": "release"
        },
        "files": [
            "out/**/*",
            "resources/**/*"
        ],
        "win": {
            "target": "nsis"
        }
    }
}
